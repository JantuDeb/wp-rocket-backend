HOST=0.0.0.0
PORT=8080
NODE_ENV=development
JOB_COMPLETE_AFTER_MS=1000
QUEUE_DRIVER=memory
REDIS_URL=redis://localhost:6379
REDIS_JOB_TTL_SECONDS=86400
START_WORKERS=true
CPCSS_TIMEOUT_MS=30000
CPCSS_FETCH_TIMEOUT_MS=10000
CPCSS_MAX_CSS_BYTES=2000000
CPCSS_DESKTOP_WIDTH=1300
CPCSS_DESKTOP_HEIGHT=900
CPCSS_MOBILE_WIDTH=390
CPCSS_MOBILE_HEIGHT=844
CPCSS_ALLOW_PRIVATE_NETWORKS=false
CPCSS_CHROMIUM_EXECUTABLE=/usr/bin/chromium
RUCSS_TIMEOUT_MS=30000
RUCSS_DESKTOP_WIDTH=1300
RUCSS_DESKTOP_HEIGHT=900
RUCSS_MOBILE_WIDTH=390
RUCSS_MOBILE_HEIGHT=844
RUCSS_ALLOW_PRIVATE_NETWORKS=false
RUCSS_CHROMIUM_EXECUTABLE=/usr/bin/chromium
PERFORMANCE_TIMEOUT_MS=30000
PERFORMANCE_DESKTOP_WIDTH=1300
PERFORMANCE_DESKTOP_HEIGHT=900
PERFORMANCE_ALLOW_PRIVATE_NETWORKS=false
PERFORMANCE_CHROMIUM_EXECUTABLE=/usr/bin/chromium
